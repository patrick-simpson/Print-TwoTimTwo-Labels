{
  "name": "awana-label-printer",
  "version": "3.0.0",
  "description": "Silent label printing for Awana check-in",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:renderer": "vite build --config renderer/vite.config.js",
    "build": "npm run build:renderer && electron-builder --win --x64",
    "dist": "npm run build:renderer && electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pdf-to-printer": "^5.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.kvbc.awana-label-printer",
    "productName": "Awana Label Printer",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "dist/**",
      "build/icon.png"
    ],
    "asarUnpack": [
      "node_modules/pdf-to-printer/**/*"
    ]
  }
}

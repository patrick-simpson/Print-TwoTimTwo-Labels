{
  "contractVersion": 2,
  "channel": "awana-channel",
  "note": "CANONICAL COPY (Print-TwoTimTwo-Labels). Mirrored byte-identical into the consumer repos (Awana-Check-in-Display, KVBC-Awana-Countdown). Privacy rule: only first names ever ride the channel — no lastName, no allergies, no contact info, no birth years.",
  "events": {
    "checkin": {
      "fields": ["id", "at", "firstName", "club", "isBirthday", "isFirstTimer"],
      "optionalForConsumers": ["id", "at"],
      "valid": [
        {
          "id": "6f9619ff-8b86-4011-b42d-00c04fc964ff",
          "at": "2026-09-16T22:05:11.000Z",
          "firstName": "Alice",
          "club": "Sparks",
          "isBirthday": false,
          "isFirstTimer": false
        },
        {
          "id": "1c5b26fe-2c0a-4a1f-9d5e-8a51a1b7c001",
          "at": "2026-09-16T22:06:00.000Z",
          "firstName": "Marcos",
          "club": "T&T",
          "isBirthday": true,
          "isFirstTimer": true
        }
      ],
      "dirty": [
        {
          "reason": "lastName must never leak to the screen",
          "payload": {
            "id": "6f9619ff-8b86-4011-b42d-00c04fc964ff",
            "at": "2026-09-16T22:05:11.000Z",
            "firstName": "Alice",
            "lastName": "Smith",
            "club": "Sparks",
            "isBirthday": false,
            "isFirstTimer": false
          },
          "mustNotContain": ["lastName", "Smith"]
        },
        {
          "reason": "allergy / contact info must never leak",
          "payload": {
            "firstName": "Tommy",
            "club": "Cubbies",
            "isBirthday": false,
            "isFirstTimer": false,
            "allergies": "peanuts",
            "phone": "555-0100"
          },
          "mustNotContain": ["allergies", "peanuts", "phone", "555-0100"]
        }
      ],
      "reject": [
        { "reason": "missing firstName", "payload": { "club": "Sparks", "isBirthday": false, "isFirstTimer": false } },
        { "reason": "non-object", "payload": "Alice checked in" },
        { "reason": "null", "payload": null }
      ]
    },
    "recap": {
      "fields": ["entries", "at"],
      "entryFields": ["id", "at", "firstName", "club", "isBirthday", "isFirstTimer"],
      "maxEntries": 30,
      "valid": [
        {
          "entries": [
            {
              "id": "6f9619ff-8b86-4011-b42d-00c04fc964ff",
              "at": "2026-09-16T22:05:11.000Z",
              "firstName": "Alice",
              "club": "Sparks",
              "isBirthday": false,
              "isFirstTimer": false
            }
          ],
          "at": "2026-09-16T22:07:00.000Z"
        },
        { "entries": [], "at": "2026-09-16T22:07:00.000Z" }
      ],
      "dirty": [
        {
          "reason": "entry smuggling a lastName must be stripped or dropped",
          "payload": {
            "entries": [
              {
                "id": "1c5b26fe-2c0a-4a1f-9d5e-8a51a1b7c001",
                "at": "2026-09-16T22:06:00.000Z",
                "firstName": "Nora",
                "lastName": "Jones",
                "club": "Trek",
                "isBirthday": false,
                "isFirstTimer": false
              }
            ],
            "at": "2026-09-16T22:07:00.000Z"
          },
          "mustNotContain": ["lastName", "Jones"]
        },
        {
          "reason": "entries without id/at cannot be deduped — dropped",
          "payload": {
            "entries": [
              { "firstName": "Chase", "club": "T&T", "isBirthday": false, "isFirstTimer": false }
            ],
            "at": "2026-09-16T22:07:00.000Z"
          },
          "expectEntryCount": 0
        }
      ],
      "reject": [
        { "reason": "entries not an array", "payload": { "entries": "Alice", "at": "2026-09-16T22:07:00.000Z" } },
        { "reason": "null", "payload": null }
      ]
    },
    "tally": {
      "fields": ["counts", "total", "at"],
      "maxClubs": 30,
      "valid": [
        {
          "counts": { "Sparks": 12, "T&T": 19, "Cubbies": 7, "Puggles": 3 },
          "total": 41,
          "at": "2026-09-16T22:07:00.000Z"
        },
        { "counts": {}, "total": 0, "at": "2026-09-16T22:07:00.000Z" }
      ],
      "dirty": [
        {
          "reason": "counts must be numbers only — a name smuggled as a value is dropped",
          "payload": {
            "counts": { "Sparks": 12, "T&T": "Alice Smith" },
            "total": 12,
            "at": "2026-09-16T22:07:00.000Z"
          },
          "mustNotContain": ["Alice Smith"]
        }
      ],
      "reject": [
        { "reason": "counts missing", "payload": { "total": 5, "at": "2026-09-16T22:07:00.000Z" } },
        { "reason": "no timestamp", "payload": { "counts": { "Sparks": 1 }, "total": 1 } }
      ]
    },
    "birthdays": {
      "fields": ["entries", "at"],
      "entryFields": ["firstName", "club", "month", "day"],
      "maxEntries": 40,
      "valid": [
        {
          "entries": [
            { "firstName": "Maya", "club": "Puggles", "month": 9, "day": 18 },
            { "firstName": "Sydney", "club": "Sparks", "month": 12, "day": 30 }
          ],
          "at": "2026-09-16T22:00:00.000Z"
        },
        { "entries": [], "at": "2026-09-16T22:00:00.000Z" }
      ],
      "dirty": [
        {
          "reason": "no lastName, no birth year — ever",
          "payload": {
            "entries": [
              { "firstName": "Maya", "lastName": "Nguyen", "club": "Puggles", "month": 9, "day": 18, "year": 2020 }
            ],
            "at": "2026-09-16T22:00:00.000Z"
          },
          "mustNotContain": ["lastName", "Nguyen", "year", "2020"]
        },
        {
          "reason": "out-of-range month/day entries are dropped",
          "payload": {
            "entries": [
              { "firstName": "Ghost", "club": "Sparks", "month": 13, "day": 40 }
            ],
            "at": "2026-09-16T22:00:00.000Z"
          },
          "expectEntryCount": 0
        }
      ],
      "reject": [
        { "reason": "entries not an array", "payload": { "entries": {}, "at": "2026-09-16T22:00:00.000Z" } },
        { "reason": "null", "payload": null }
      ]
    },
    "ops": {
      "fields": ["type", "at"],
      "optionalFields": ["club"],
      "types": ["print-failure", "canary", "selector-fail"],
      "valid": [
        { "type": "print-failure", "club": "Sparks", "at": "2026-09-16T22:10:00.000Z" },
        { "type": "selector-fail", "at": "2026-09-16T22:10:00.000Z" }
      ],
      "dirty": [
        {
          "reason": "ops events carry type/club/at ONLY — never a name",
          "payload": { "type": "print-failure", "club": "Sparks", "name": "Alice Smith", "at": "2026-09-16T22:10:00.000Z" },
          "mustNotContain": ["name", "Alice Smith"]
        }
      ],
      "reject": [
        { "reason": "unknown type", "payload": { "type": "reboot-everything", "at": "2026-09-16T22:10:00.000Z" } },
        { "reason": "missing type", "payload": { "club": "Sparks", "at": "2026-09-16T22:10:00.000Z" } }
      ]
    },
    "canary": {
      "fields": ["at"],
      "optionalFields": ["nonce"],
      "valid": [
        { "at": "2026-09-16T21:40:00.000Z", "nonce": "a1b2c3d4e5f60718" },
        { "at": "2026-09-16T21:40:00.000Z" }
      ],
      "dirty": [],
      "reject": [
        { "reason": "no timestamp", "payload": { "nonce": "a1b2c3d4e5f60718" } }
      ]
    }
  }
}

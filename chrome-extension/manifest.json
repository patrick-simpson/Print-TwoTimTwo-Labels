{
  "manifest_version": 3,
  "name": "KVBC Kids Check-in Extension",
  "version": "2.0.1",
  "description": "Automatically detect check-ins and send them to the local KVBC Print Server.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:3456/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twotimtwo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}

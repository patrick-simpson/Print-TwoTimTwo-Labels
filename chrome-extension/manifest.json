{
  "manifest_version": 3,
  "name": "Twotimtwo Auto Printer",
  "version": "1.0",
  "description": "Automatically prints labels upon check-in on twotimtwo.",
  "permissions": [
    "storage",
    "printing"
  ],
  "host_permissions": [
    "*://*.twotimtwo.com/*",
    "http://localhost/*",
    "*://*.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twotimtwo.com/*", "http://localhost/*", "*://*.run.app/*"],
      "js": ["lib/jspdf.umd.min.js", "content.js"]
    }
  ]
}

{
  "manifest_version": 3,
  "name": "Twotimtwo Auto Printer",
  "version": "1.1",
  "description": "Silently prints name labels upon check-in on twotimtwo.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.twotimtwo.com/*",
    "http://localhost/*",
    "*://*.run.app/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Twotimtwo Auto Printer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twotimtwo.com/*", "http://localhost/*", "*://*.run.app/*"],
      "js": ["content.js"]
    }
  ]
}
